<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FragmentSo1"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <ImageView
            android:id="@+id/anh1"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:src="@drawable/anh1"
            android:layout_marginTop="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/t1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore the app"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="#333333"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/anh1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/t2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Now your finances are in one place and always under control"
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="#888888"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="40dp"
            app:layout_constraintTop_toBottomOf="@id/t1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnsignin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Sign In"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/btn_green"
            android:layout_marginTop="50dp"
            app:layout_constraintTop_toBottomOf="@id/t2" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_create"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Create account"
            android:textAllCaps="false"
            android:textColor="#6B9E78"
            android:textSize="16sp"
            android:background="@drawable/btn_white_border"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnsignin" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>