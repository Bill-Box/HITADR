<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/btn_back_border"
        android:background="@drawable/btn_box_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/img_logo"
        android:layout_width="100dp"
        android:layout_height="80dp"
        android:src="@drawable/anh1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please check your email"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/img_logo"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_sub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="We've sent a code to helloworld@gmail.com"
        android:textColor="#888888"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layout_otp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/tv_sub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:layout_width="65dp"
            android:layout_height="75dp"
            android:text="8"
            android:gravity="center"
            android:textSize="22sp"
            android:background="@drawable/btn_box_white"
            android:layout_margin="6dp"/>

        <EditText
            android:layout_width="65dp"
            android:layout_height="75dp"
            android:text="2"
            android:gravity="center"
            android:textSize="22sp"
            android:background="@drawable/btn_box_white"
            android:layout_margin="6dp"/>

        <EditText
            android:layout_width="65dp"
            android:layout_height="75dp"
            android:text="2"
            android:gravity="center"
            android:textSize="22sp"
            android:background="@drawable/btn_box_white"
            android:layout_margin="6dp"/>

        <EditText
            android:layout_width="65dp"
            android:layout_height="75dp"
            android:gravity="center"
            android:background="@drawable/btn_box_white"
            android:layout_margin="6dp"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_verify"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Verify"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_green"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/layout_otp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Send code again 00:20"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_verify"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>