<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/header"
    tools:context=".MainActivity">

    <!-- Ảnh nền Header -->
    <ImageView
        android:id="@+id/imgHeader"
        android:layout_width="320dp"
        android:layout_height="220dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_header"
        app:layout_constraintBottom_toTopOf="@+id/imgMain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        android:text="0"
        android:textColor="#44403D"
        android:textSize="60sp"
        android:textStyle="bold"
        android:gravity="bottom|end"
        app:layout_constraintBottom_toBottomOf="@+id/imgHeader"
        app:layout_constraintEnd_toEndOf="@+id/imgHeader"
        app:layout_constraintStart_toStartOf="@+id/imgHeader"
        app:layout_constraintTop_toTopOf="@+id/imgHeader" />

    <ImageView
        android:id="@+id/imgMain"
        android:layout_width="320dp"
        android:layout_height="380dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_main"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgHeader" />
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="@+id/imgMain"
        app:layout_constraintEnd_toEndOf="@+id/imgMain"
        app:layout_constraintStart_toStartOf="@+id/imgMain"
        app:layout_constraintTop_toTopOf="@+id/imgMain">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <Button
                    android:id="@+id/btnAC"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#D8A484"
                    android:onClick="onClearClick"
                    android:text="AC"
                    android:textColor="#44403D"
                    android:textSize="22sp" />
                <Button
                    android:id="@+id/btn7"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="7"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn4"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="4"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn1"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="1"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#988E83"
                    android:onClick="onDeleteClick"
                    android:text="&lt;"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn8"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="8"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn5"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="5"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn2"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="2"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <Button
                    android:id="@+id/btnPercent"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#988E83"
                    android:onClick="onOperatorClick"
                    android:text="%"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn9"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="9"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn6"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="6"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btn3"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#E3E0D8"
                    android:onClick="onNumberClick"
                    android:text="3"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <Button
                    android:id="@+id/btnDiv"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#988E83"
                    android:onClick="onOperatorClick"
                    android:text="/"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btnMul"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#988E83"
                    android:onClick="onOperatorClick"
                    android:text="*"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btnMinus"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#988E83"
                    android:onClick="onOperatorClick"
                    android:text="-"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
                <Button
                    android:id="@+id/btnPlus"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_button_round"
                    android:backgroundTint="#988E83"
                    android:onClick="onOperatorClick"
                    android:text="+"
                    android:textColor="#44403D"
                    android:textSize="25sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btn0"
                android:layout_width="144dp"
                android:layout_height="60dp"
                android:layout_margin="2dp"
                android:background="@drawable/bg_button_round"
                android:backgroundTint="#E3E0D8"
                android:onClick="onNumberClick"
                android:text="0"
                android:textColor="#44403D"
                android:textSize="25sp" />
            <Button
                android:id="@+id/btnEqual"
                android:layout_width="144dp"
                android:layout_height="60dp"
                android:layout_margin="2dp"
                android:background="@drawable/bg_button_round"
                android:backgroundTint="#988E83"
                android:onClick="onEqualClick"
                android:text="="
                android:textColor="#44403D"
                android:textSize="25sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>